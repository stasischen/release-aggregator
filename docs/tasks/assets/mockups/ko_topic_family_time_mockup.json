      "kind": "pattern_frame",
      "title_zh_tw": "今天是星期幾",
      "surface": "오늘은 N요일이에요",
      "level": "A1",
      "summary_zh_tw": "最直接的星期表達句型，適合做主題頁第一個高亮框架。",
      "topic_refs": [
        "topic.time.weekday"
      ],
      "example_bank": [
        {
