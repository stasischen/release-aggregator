{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TLG-025 Item Bank v1",
  "type": "object",
  "required": [
    "bank_id",
    "version",
    "target_lang",
    "support_langs",
    "level",
    "generated_at",
    "source_unit_id",
    "items"
  ],
  "properties": {
    "bank_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["v1"] },
    "target_lang": { "type": "string", "minLength": 2 },
    "support_langs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "level": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
    "generated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "source_unit_id": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "item_id",
          "item_type",
          "skill",
          "difficulty_tier",
          "prompt_zh_tw",
          "answer_key",
          "explanation_zh_tw",
          "linked_refs",
          "tags",
          "review_policy"
        ],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "item_type": { "type": "string", "enum": ["mcq_meaning", "cloze", "transform", "retrieval"] },
          "skill": { "type": "string", "enum": ["reading", "listening", "grammar", "speaking", "writing"] },
          "difficulty_tier": { "type": "string", "enum": ["L1", "L2", "L3"] },
          "prompt_zh_tw": { "type": "string", "minLength": 1 },
          "prompt_ko": { "type": "string" },
          "choices": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "answer_key": {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": { "type": "string", "enum": ["single_choice", "short_text"] },
              "value": {}
            },
            "additionalProperties": false
          },
          "explanation_zh_tw": { "type": "string", "minLength": 1 },
          "linked_refs": {
            "type": "object",
            "required": ["lesson_id", "node_id", "grammar_ids", "pattern_ids", "function_ids"],
            "properties": {
              "lesson_id": { "type": "string", "minLength": 1 },
              "node_id": { "type": "string", "minLength": 1 },
              "grammar_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "pattern_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "function_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            },
            "additionalProperties": false
          },
          "tags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "review_policy": {
            "type": "object",
            "required": ["initial_interval_days", "wrong_interval_days", "correct_fast_interval_days"],
            "properties": {
              "initial_interval_days": { "type": "integer", "minimum": 1 },
              "wrong_interval_days": { "type": "integer", "minimum": 1 },
              "correct_fast_interval_days": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
