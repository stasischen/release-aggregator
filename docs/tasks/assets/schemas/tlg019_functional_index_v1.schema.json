{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TLG-019 Functional Index v1",
  "type": "object",
  "required": ["index_id", "version", "target_lang", "support_langs", "generated_at", "entries"],
  "properties": {
    "index_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["v1"] },
    "target_lang": { "type": "string", "minLength": 2 },
    "support_langs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "generated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "function_id", "label_zh_tw", "label_en", "can_do_zh_tw", "can_do_en",
          "level_range", "lesson_refs", "pattern_refs", "grammar_refs", "context_tags",
          "prerequisite_function_ids", "teaching_hint"
        ],
        "properties": {
          "function_id": { "type": "string", "pattern": "^F-[A-Z0-9-]+$" },
          "label_zh_tw": { "type": "string", "minLength": 1 },
          "label_en": { "type": "string", "minLength": 1 },
          "can_do_zh_tw": { "type": "string", "minLength": 1 },
          "can_do_en": { "type": "string", "minLength": 1 },
          "level_range": {
            "type": "object",
            "required": ["min", "max"],
            "properties": {
              "min": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
              "max": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] }
            },
            "additionalProperties": false
          },
          "lesson_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["lesson_id", "role", "coverage_score", "evidence"],
              "properties": {
                "lesson_id": { "type": "string", "minLength": 1 },
                "role": { "type": "string", "enum": ["core", "support", "review"] },
                "coverage_score": { "type": "number", "minimum": 0, "maximum": 1 },
                "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } }
              },
              "additionalProperties": false
            }
          },
          "pattern_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "grammar_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "context_tags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "prerequisite_function_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "teaching_hint": {
            "type": "object",
            "required": ["zh_tw", "en"],
            "properties": {
              "zh_tw": { "type": "string", "minLength": 1 },
              "en": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
