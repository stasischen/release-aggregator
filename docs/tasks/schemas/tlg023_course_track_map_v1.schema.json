{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TLG-023 Course Track Map v1",
  "type": "object",
  "required": [
    "map_id",
    "version",
    "target_lang",
    "support_langs",
    "level",
    "generated_at",
    "maintenance_note",
    "lessons"
  ],
  "properties": {
    "map_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["v1"] },
    "target_lang": { "type": "string", "minLength": 2 },
    "support_langs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },
    "level": {
      "type": "string",
      "enum": ["A1", "A2", "B1", "B2", "C1", "C2"]
    },
    "generated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "maintenance_note": {
      "type": "object",
      "required": [
        "sync_rule_zh_tw",
        "sync_rule_en",
        "markdown_generator_command"
      ],
      "properties": {
        "sync_rule_zh_tw": { "type": "string", "minLength": 1 },
        "sync_rule_en": { "type": "string", "minLength": 1 },
        "markdown_generator_command": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "lessons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "lesson_id",
          "sequence_no",
          "track_type",
          "title_zh_tw",
          "title_en",
          "primary_objective_id",
          "secondary_objective_ids",
          "context_ids",
          "pattern_ids",
          "grammar_ids",
          "function_ids",
          "prerequisites",
          "bridge_to_track",
          "node_profile"
        ],
        "properties": {
          "lesson_id": { "type": "string", "minLength": 1 },
          "sequence_no": { "type": "integer", "minimum": 1 },
          "track_type": { "type": "string", "enum": ["functional", "grammar"] },
          "title_zh_tw": { "type": "string", "minLength": 1 },
          "title_en": { "type": "string", "minLength": 1 },
          "primary_objective_id": { "type": "string", "minLength": 1 },
          "secondary_objective_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "context_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "pattern_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "grammar_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "function_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "prerequisites": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "bridge_to_track": {
            "type": "object",
            "required": [
              "recommended_next_functional_lesson_id",
              "recommended_next_grammar_lesson_id",
              "bridge_note_zh_tw",
              "bridge_note_en"
            ],
            "properties": {
              "recommended_next_functional_lesson_id": {
                "type": ["string", "null"],
                "minLength": 1
              },
              "recommended_next_grammar_lesson_id": {
                "type": ["string", "null"],
                "minLength": 1
              },
              "bridge_note_zh_tw": { "type": "string", "minLength": 1 },
              "bridge_note_en": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "node_profile": {
            "type": "object",
            "required": [
              "required_node_types",
              "max_nodes",
              "min_nodes",
              "must_include_anchor"
            ],
            "properties": {
              "required_node_types": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "max_nodes": { "type": "integer", "minimum": 1 },
              "min_nodes": { "type": "integer", "minimum": 1 },
              "must_include_anchor": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
