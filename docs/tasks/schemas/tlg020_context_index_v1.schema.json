{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TLG-020 Context Index v1",
  "type": "object",
  "required": ["index_id", "version", "target_lang", "support_langs", "generated_at", "entries"],
  "properties": {
    "index_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["v1"] },
    "target_lang": { "type": "string", "minLength": 2 },
    "support_langs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "generated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "context_id", "label_zh_tw", "label_en", "domain", "subdomain", "level_range",
          "lesson_refs", "function_refs", "pattern_refs", "grammar_refs",
          "transfer_contexts", "task_outcomes"
        ],
        "properties": {
          "context_id": { "type": "string", "pattern": "^CTX-[A-Z]{2,6}-[A-Z0-9-]+$" },
          "label_zh_tw": { "type": "string", "minLength": 1 },
          "label_en": { "type": "string", "minLength": 1 },
          "domain": { "type": "string", "minLength": 1 },
          "subdomain": { "type": "string", "minLength": 1 },
          "level_range": {
            "type": "object",
            "required": ["min", "max"],
            "properties": {
              "min": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
              "max": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] }
            },
            "additionalProperties": false
          },
          "lesson_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["lesson_id", "role", "coverage_score", "evidence"],
              "properties": {
                "lesson_id": { "type": "string", "minLength": 1 },
                "role": { "type": "string", "enum": ["primary", "secondary", "review"] },
                "coverage_score": { "type": "number", "minimum": 0, "maximum": 1 },
                "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } }
              },
              "additionalProperties": false
            }
          },
          "function_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "pattern_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "grammar_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "transfer_contexts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "task_outcomes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
