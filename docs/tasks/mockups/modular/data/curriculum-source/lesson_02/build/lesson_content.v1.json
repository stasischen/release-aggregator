{
  "version": "unit_blueprint_v0.1",
  "unit": {
    "unit_id": "A1-BG-L02",
    "title_i18n": {
      "zh_tw": "文法 02：三大核心助詞 (은/는, 이/가, 을/를)",
      "en": "Grammar 02: The Three Core Particles (은/는, 이/가, 을/를)"
    },
    "theme_i18n": {
      "zh_tw": "誰在說話、誰在做事、動作的對象",
      "en": "Who is talking, who is doing, and the object of action"
    },
    "target_language": "ko",
    "learner_locale_source": "zh_tw",
    "level": "A1",
    "output_ratio_target": 0.55,
    "can_do_i18n": [
      {
        "zh_tw": "你能區分 은/는 和 이/가 的使用場景 (主題 vs 主語)。",
        "en": "Distinguish between 은/는 and 이/가 (Topic vs Subject)."
      },
      {
        "zh_tw": "你能正確在受詞後加上 을/를。",
        "en": "Correctly apply the object markers 을/를."
      },
      {
        "zh_tw": "你能區分『我是學生』(一般介紹) 和『我才是學生』(指名主角) 的差別。",
        "en": "Tell the difference between 'I am a student' (intro) and 'I (am the one who) am a student' (focus)."
      },
      {
        "zh_tw": "你能正確造出包含主語、受詞、動詞的簡單動作句。",
        "en": "Build basic sentence structures including subject, object, and verb."
      }
    ],
    "grammar_cluster": [
      "은/는",
      "이/가",
      "을/를"
    ]
  },
  "sequence": [
    {
      "id": "A1-BG-L02-L1",
      "candidate_type": "lesson",
      "content_form": "dialogue",
      "learning_role": "immersion_input",
      "skill_focus": [
        "listening",
        "reading"
      ],
      "output_mode": "none",
      "duration_min": 6,
      "payload": {
        "what_to_notice_i18n": [
          {
            "zh_tw": "注意指名「誰」要請客時用 누가/제가，以及切換到「午餐」這個新話題時用 점심은。",
            "en": "Notice how 누가/제가 is used to spotlight 'who' pays, and how 은/는 shifts the topic to lunch."
          }
        ],
        "dialogue_turns": [
          {
            "speaker": "A",
            "text": "우리 커피 마셔요. 누가 사요?",
            "zh_tw": "我們喝咖啡吧。誰要請客？",
            "en": "Let's drink coffee. Who's paying?"
          },
          {
            "speaker": "B",
            "text": "제가 사요! 제가 오늘 기분이 좋아요.",
            "zh_tw": "我來請！我今天心情很好。",
            "en": "I'll pay! I'm in a good mood today."
          },
          {
            "speaker": "A",
            "text": "아, 진짜요? 고마워요! 그럼 점심은 제가 사요.",
            "zh_tw": "啊，真的嗎？謝謝！那午飯（的話）就由我來請。",
            "en": "Ah, really? Thanks! Then as for lunch, I'll pay."
          }
        ],
        "dialogue_scenes": [
          {
            "scene_id": "cafe_payment",
            "title_i18n": {
              "zh_tw": "誰要請客？(Cafe Payment)",
              "en": "Who's paying? (Cafe Payment)"
            },
