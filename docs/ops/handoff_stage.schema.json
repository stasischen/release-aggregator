{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lingo.local/schemas/handoff_stage.schema.json",
  "title": "Stage Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stage_id",
    "repo",
    "source_commit",
    "schema_version",
    "inputs",
    "outputs",
    "gate_results",
    "status",
    "generated_at"
  ],
  "properties": {
    "stage_id": {
      "type": "string",
      "pattern": "^STAGE-[0-9]{2}$"
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "gate_results": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "boolean" },
          { "type": "number" },
          { "type": "integer" },
          { "type": "string" }
        ]
      },
      "minProperties": 1
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
