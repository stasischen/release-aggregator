      "id": "A1-GL01-L2",
      "candidate_type": "path_node",
      "content_form": "grammar_note",
      "learning_role": "immersion_input",
      "skill_focus": ["reading", "grammar"],
      "output_mode": "none",
      "duration_min": 8,
      "title_zh_tw": "L2 日常最常用：아요/어요/해요",
      "summary_zh_tw": "這個是你每天最常講的版本，先練熟最有感。",
      "expected_output_zh_tw": "你能用日常禮貌體快速造句。",
      "payload": {
        "sections": [
          {
            "title_zh_tw": "先記一句：不確定就先用요",
            "explanation_md": "`~아요/어요/해요` 是你日常最常用、最安全的語氣。\\n\\n不會太正式，也不會太隨便。\\n\\n跟朋友、同學、老師、陌生人聊天都很常見。"
          },
          {
            "title_zh_tw": "規則先用這三條",
            "points_zh_tw": [
              "字幹母音 ㅏ/ㅗ -> 아요",
              "其他母音 -> 어요",
              "하다 -> 해요"
            ]
          },
          {
            "title_zh_tw": "高頻句一口氣帶走",
            "points_zh_tw": [
              "집에 가요.（回家）",
              "밥을 먹어요.（吃飯）",
              "책을 읽어요.（看書）",
              "커피 마셔요.（喝咖啡）",
              "노래 들어요.（聽歌）",
              "버스를 타요.（搭公車）",
              "영화 봐요.（看電影）",
              "운동해요.（運動）",
              "숙제해요.（做作業）",
              "친구한테 전화해요.（打電話給朋友）"
            ]
          }
        ]
      },
      "adapter_hints": {"content_renderer_key": "grammar_note", "interaction_renderer_key": null}
    },
