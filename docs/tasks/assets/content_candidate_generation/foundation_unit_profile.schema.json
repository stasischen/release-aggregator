{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://release-aggregator.local/schemas/foundation-unit-profile-v1.json",
  "title": "Foundation Unit Profile v1",
  "description": "Profile contract for modular, reusable multilingual unit scaffolding.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "version",
    "display_name",
    "target_levels",
    "default_output_ratio_target",
    "constraints",
    "node_plan"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "target_levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "default_output_ratio_target": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_node_count",
        "required_learning_roles",
        "output_mode_targets",
        "require_resource_links_for_output_nodes"
      ],
      "properties": {
        "min_node_count": {
          "type": "integer",
          "minimum": 1
        },
        "required_learning_roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "output_mode_targets": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 1
          }
        },
        "require_resource_links_for_output_nodes": {
          "type": "boolean"
        }
      }
    },
    "node_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "node_suffix",
          "template_id"
        ],
        "properties": {
          "node_suffix": {
            "type": "string",
            "pattern": "^[A-Z][0-9]+$"
          },
          "template_id": {
            "type": "string",
            "minLength": 1
          },
          "title_suffix_zh_tw": {
            "type": "string"
          },
          "depends_on_suffixes": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Z][0-9]+$"
            },
            "default": []
          },
          "optional": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  }
}
