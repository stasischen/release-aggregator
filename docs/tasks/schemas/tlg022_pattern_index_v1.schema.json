{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TLG-022 Pattern Index v1",
  "type": "object",
  "required": ["index_id", "version", "target_lang", "support_langs", "generated_at", "entries"],
  "properties": {
    "index_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["v1"] },
    "target_lang": { "type": "string", "minLength": 2 },
    "support_langs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "generated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "pattern_id", "frame", "aliases", "level", "lesson_refs",
          "function_refs", "grammar_refs", "context_refs", "transform_types",
          "repair_links", "teaching_hint"
        ],
        "properties": {
          "pattern_id": { "type": "string", "pattern": "^ko-[A-Z0-9a-z-]+$" },
          "frame": { "type": "string", "minLength": 1 },
          "aliases": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "level": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
          "lesson_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["lesson_id", "role", "coverage_score", "evidence"],
              "properties": {
                "lesson_id": { "type": "string", "minLength": 1 },
                "role": { "type": "string", "enum": ["primary", "reinforce", "review"] },
                "coverage_score": { "type": "number", "minimum": 0, "maximum": 1 },
                "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } }
              },
              "additionalProperties": false
            }
          },
          "function_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "grammar_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "context_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "transform_types": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "repair_links": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "teaching_hint": {
            "type": "object",
            "required": ["zh_tw", "en"],
            "properties": {
              "zh_tw": { "type": "string", "minLength": 1 },
              "en": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
