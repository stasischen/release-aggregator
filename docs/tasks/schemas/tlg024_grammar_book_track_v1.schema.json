{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TLG-024 Grammar Book Track v1",
  "type": "object",
  "required": [
    "track_id",
    "version",
    "target_lang",
    "support_langs",
    "level",
    "generated_at",
    "source_refs",
    "chapters",
    "lessons"
  ],
  "properties": {
    "track_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["v1"] },
    "target_lang": { "type": "string", "minLength": 2 },
    "support_langs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
    "level": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
    "generated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "source_refs": {
      "type": "object",
      "required": ["lllo_curriculum_map", "content_ko_core_grammar", "content_ko_core_dialogue"],
      "properties": {
        "lllo_curriculum_map": { "type": "string", "minLength": 1 },
        "content_ko_core_grammar": { "type": "string", "minLength": 1 },
        "content_ko_core_dialogue": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["chapter_id", "title_zh_tw", "title_en", "lesson_ids"],
        "properties": {
          "chapter_id": { "type": "string", "minLength": 1 },
          "title_zh_tw": { "type": "string", "minLength": 1 },
          "title_en": { "type": "string", "minLength": 1 },
          "lesson_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        },
        "additionalProperties": false
      }
    },
    "lessons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "lesson_id",
          "sequence_no",
          "delivery_mode",
          "legacy_ref",
          "anchor_dialogue",
          "content_integration",
          "grammar_focus_id",
          "grammar_subpoints",
          "teaching_structure",
          "example_sources",
          "practice_blueprint",
          "bridge_to_survival"
        ],
        "properties": {
          "lesson_id": { "type": "string", "minLength": 1 },
          "sequence_no": { "type": "integer", "minimum": 1 },
          "delivery_mode": { "type": "string", "enum": ["dialogue_first"] },
          "legacy_ref": {
            "type": "object",
            "required": ["lllo_directory_name", "content_ko_lesson_id"],
            "properties": {
              "lllo_directory_name": { "type": "string", "minLength": 1 },
              "content_ko_lesson_id": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "anchor_dialogue": {
            "type": "object",
            "required": ["source_segment_id", "line_window", "teaching_goal_zh_tw"],
            "properties": {
              "source_segment_id": { "type": "string", "minLength": 1 },
              "line_window": { "type": "string", "pattern": "^\\d+-\\d+$" },
              "teaching_goal_zh_tw": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "content_integration": {
            "type": "object",
            "required": ["micro_text_theme", "communicative_task", "activation_prompt_zh_tw"],
            "properties": {
              "micro_text_theme": { "type": "string", "minLength": 1 },
              "communicative_task": { "type": "string", "minLength": 1 },
              "activation_prompt_zh_tw": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "grammar_focus_id": { "type": "string", "minLength": 1 },
          "grammar_subpoints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "teaching_structure": {
            "type": "object",
            "required": ["form", "meaning", "use", "minimal_pair", "common_errors"],
            "properties": {
              "form": { "type": "string", "minLength": 1 },
              "meaning": { "type": "string", "minLength": 1 },
              "use": { "type": "string", "minLength": 1 },
              "minimal_pair": { "type": "string", "minLength": 1 },
              "common_errors": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            },
            "additionalProperties": false
          },
          "example_sources": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "practice_blueprint": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["recognize", "fill", "transform", "build"] }
          },
          "bridge_to_survival": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
